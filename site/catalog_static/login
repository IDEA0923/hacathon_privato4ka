<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход в систему</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --accent: #38bdf8;
            --accent-hover: #7dd3fc;
            --text: #f8fafc;
            --error: #ef4444;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top right, #1e293b, var(--bg-color));
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
            overflow: hidden;
        }

        .login-container {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            padding: 2.5rem;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
            max-width: 400px;
            transform: translateY(0);
            transition: all 0.3s ease;
        }

        h2 {
            text-align: center;
            margin-bottom: 2rem;
            font-weight: 300;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .input-group {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .input-group input {
            width: 100%;
            padding: 12px 0;
            background: transparent;
            border: none;
            border-bottom: 2px solid #475569;
            color: var(--text);
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
        }

        .input-group label {
            position: absolute;
            top: 12px;
            left: 0;
            pointer-events: none;
            color: #94a3b8;
            transition: all 0.3s ease;
        }

        /* Анимация лейбла при фокусе или наличии текста */
        .input-group input:focus ~ label,
        .input-group input:not(:placeholder-shown) ~ label {
            top: -12px;
            font-size: 0.8rem;
            color: var(--accent);
            letter-spacing: 1px;
        }

        .input-group input:focus {
            border-bottom-color: var(--accent);
        }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            border: none;
            border-radius: 10px;
            color: #0f172a;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 1.5rem;
            box-shadow: 0 4px 15px rgba(56, 189, 248, 0.2);
        }

        .login-btn:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(56, 189, 248, 0.4);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .login-btn:disabled {
            background: #475569;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .footer-links {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.85rem;
            opacity: 0.8;
        }

        .footer-links a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer-links a:hover {
            color: var(--accent);
        }

        /* Сообщение об ошибке */
        #error-msg {
            color: var(--error);
            font-size: 0.85rem;
            text-align: center;
            margin-top: 10px;
            min-height: 20px;
            display: none;
        }

        /* Плавное появление контейнера */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-container {
            animation: fadeIn 0.6s ease-out;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <form id="authForm">
            <h2>Вход</h2>
            
            <div class="input-group">
                <input type="text" id="username" name="username" required placeholder=" ">
                <label for="username">Имя пользователя</label>
            </div>
            
            <div class="input-group">
                <input type="password" id="password" name="password" required placeholder=" ">
                <label for="password">Пароль</label>
            </div>

            <div id="error-msg">Неверный логин или пароль</div>

            <button type="submit" id="submitBtn" class="login-btn">ВОЙТИ</button>
            
            <div class="footer-links">
                <a href="https://t.me/esp_home_alertbot">Регистрация</a>
                <span style="margin: 0 10px;">•</span>
                <a href="https://t.me/esp_home_iot">Забыли пароль?</a>
            </div>
        </form>
    </div>

    <script>
        const authForm = document.getElementById('authForm');
        const submitBtn = document.getElementById('submitBtn');
        const errorMsg = document.getElementById('error-msg');

        authForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Визуальный фидбек
            submitBtn.disabled = true;
            submitBtn.innerText = 'ЗАГРУЗКА...';
            errorMsg.style.display = 'none';

            const formData = new FormData(authForm);
            const payload = Object.fromEntries(formData.entries());

            try {
                // ВАЖНО: замени '/login' на свой реальный путь в C++ сервере
                const response = await fetch('/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const result = await response.json();
                    console.log('Success:', result);
                    // Перенаправление при успехе
                    window.location.href = '/dashboard'; 
                } else {
                    // Обработка ошибок (401, 403, 500 и т.д.)
                    errorMsg.innerText = 'Ошибка доступа: ' + response.status;
                    errorMsg.style.display = 'block';
                }
            } catch (err) {
                console.error('Fetch error:', err);
                errorMsg.innerText = 'Сервер недоступен';
                errorMsg.style.display = 'block';
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerText = 'ВОЙТИ';
            }
        });
    </script>
</body>
</html